# Sylvander server environment config
# Source this file before running: source sylvander.env

# Anthropic API (via token9 proxy)
export ANTHROPIC_API_KEY="sk-sylvander-dev"
export ANTHROPIC_BASE_URL="http://token9.oraculo.ai:9527"

# Model
export SYLVANDER_MODEL="deepseek-v4-flash"

# DingTalk channel (optional — omit to run agent-only)
export DINGTALK_APP_KEY=""
export DINGTALK_APP_SECRET=""

# Optional: enable tool approval
# export SYLVANDER_APPROVAL=1

# Log level
export RUST_LOG="info,sylvander=debug"
