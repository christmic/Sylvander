{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Sylvander TUI Current",
    "version": "4.1",
    "sourceOfTruth": "docs/sylvander-tui-ux-design.md"
  },
  "color": {
    "canvas": { "$value": "#000000", "$type": "color" },
    "text": { "$value": "#ECE7DE", "$type": "color" },
    "textDim": { "$value": "#989B9D", "$type": "color" },
    "textMuted": { "$value": "#666C72", "$type": "color" },
    "rule": { "$value": "#343A40", "$type": "color" },
    "brandWarm": { "$value": "#F0BE72", "$type": "color" },
    "brandViolet": { "$value": "#9B72FF", "$type": "color" },
    "active": { "$value": "#75A7E8", "$type": "color" },
    "verified": { "$value": "#72C7B1", "$type": "color" },
    "waiting": { "$value": "#D9AF62", "$type": "color" },
    "danger": { "$value": "#E06C75", "$type": "color" }
  },
  "terminal": {
    "layout": {
      "leftGutterCells": { "$value": 2, "$type": "number" },
      "readingMaxCells": { "$value": 110, "$type": "number" },
      "welcomeHorizontalMinCells": { "$value": 88, "$type": "number" },
      "welcomeCharacterCells": { "$value": 44, "$type": "number" },
      "welcomeGapCells": { "$value": 4, "$type": "number" },
      "composerMinRows": { "$value": 1, "$type": "number" },
      "composerMaxRows": { "$value": 8, "$type": "number" },
      "decisionMaxCells": { "$value": 110, "$type": "number" },
      "pickerRowsStandard": { "$value": 8, "$type": "number" },
      "pickerRowsNarrow": { "$value": 4, "$type": "number" },
      "reviewCodeMaxCells": { "$value": 160, "$type": "number" }
    },
    "symbols": {
      "userTurn": { "$value": "›", "$type": "string" },
      "agentTurn": { "$value": "◆", "$type": "string" },
      "composerPrompt": { "$value": ">", "$type": "string" },
      "working": { "$value": "◌", "$type": "string" },
      "verified": { "$value": "✓", "$type": "string" },
      "failed": { "$value": "!", "$type": "string" }
    }
  }
}
